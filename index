<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VOI MAZE — Blockchain Learning Game</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap');

  :root {
    --bg: #050a0f;
    --panel: #080f17;
    --border: #0ff3;
    --accent: #00f5ff;
    --accent2: #7b00ff;
    --accent3: #ff006e;
    --warn: #ffb800;
    --correct: #00ff9d;
    --wrong: #ff3860;
    --text: #c8e0f0;
    --dim: #4a6878;
    --glow: 0 0 12px #00f5ff88, 0 0 30px #00f5ff33;
    --glow2: 0 0 12px #7b00ff88;
    --cell: 40px;
    /* Power-up colors */
    --pu-freeze: #00cfff;
    --pu-hint: #ffe600;
    --pu-boost: #ff6b35;
    --pu-reveal: #b400ff;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Rajdhani', sans-serif;
    min-height: 100vh;
    overflow: hidden;
    position: relative;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, #00000018 2px, #00000018 4px);
    pointer-events: none;
    z-index: 1000;
  }
  body::after {
    content: '';
    position: fixed; inset: 0;
    background-image: linear-gradient(#0ff08 1px, transparent 1px), linear-gradient(90deg, #0ff08 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.15;
    pointer-events: none;
  }

  /* ─── SCREENS ─── */
  .screen {
    position: fixed; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 10; transition: opacity 0.5s;
  }
  .screen.hidden { opacity: 0; pointer-events: none; }

  /* ─── START ─── */
  #startScreen { background: radial-gradient(ellipse at 50% 30%, #0a1a2a 0%, #050a0f 70%); gap: 20px; }

  .logo-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(42px, 8vw, 80px);
    font-weight: 900;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-shadow: var(--glow), 0 0 60px #00f5ff44;
    animation: pulse 3s ease-in-out infinite;
  }
  .logo-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: clamp(10px, 1.8vw, 13px);
    color: var(--dim);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin-top: 4px;
    text-align: center;
  }
  @keyframes pulse {
    0%,100% { text-shadow: var(--glow), 0 0 60px #00f5ff44; }
    50% { text-shadow: 0 0 20px #00f5ffcc, 0 0 60px #00f5ff88, 0 0 100px #00f5ff44; }
  }

  .start-form {
    display: flex; flex-direction: column;
    align-items: center; gap: 12px;
    width: 340px;
  }
  .cyber-input {
    width: 100%;
    background: #0a1520;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 12px 16px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 15px;
    outline: none;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    transition: box-shadow 0.2s;
  }
  .cyber-input:focus { box-shadow: var(--glow); }
  .cyber-input::placeholder { color: var(--dim); }

  .difficulty-row {
    display: flex; gap: 8px; width: 100%;
  }
  .diff-btn {
    flex: 1;
    background: #0a1520;
    border: 1px solid var(--dim);
    color: var(--dim);
    padding: 8px 4px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .diff-btn.active-easy { border-color: var(--correct); color: var(--correct); background: #001a0d; box-shadow: 0 0 8px #00ff9d44; }
  .diff-btn.active-normal { border-color: var(--accent); color: var(--accent); background: #00141a; box-shadow: 0 0 8px #00f5ff44; }
  .diff-btn.active-hard { border-color: var(--wrong); color: var(--wrong); background: #1a0005; box-shadow: 0 0 8px #ff386044; }

  .cyber-btn {
    width: 100%;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 13px 24px;
    font-family: 'Orbitron', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    clip-path: polygon(12px 0%, 100% 0%, calc(100% - 12px) 100%, 0% 100%);
    transition: all 0.2s;
    position: relative; overflow: hidden;
  }
  .cyber-btn::before {
    content: ''; position: absolute; inset: 0;
    background: var(--accent);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.2s; z-index: -1;
  }
  .cyber-btn:hover { color: var(--bg); box-shadow: var(--glow); }
  .cyber-btn:hover::before { transform: scaleX(1); }
  .cyber-btn.secondary { border-color: var(--accent2); color: var(--accent2); }
  .cyber-btn.secondary::before { background: var(--accent2); }
  .cyber-btn.secondary:hover { box-shadow: var(--glow2); }
  .cyber-btn.danger { border-color: var(--wrong); color: var(--wrong); }
  .cyber-btn.danger::before { background: var(--wrong); }

  .divider {
    width: 100%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    margin: 4px 0; opacity: 0.4;
  }

  /* ─── GAME SCREEN ─── */
  #gameScreen {
    flex-direction: row; align-items: stretch;
    justify-content: flex-start;
    background: var(--bg); padding: 0;
  }
  #gameCanvas { display: block; image-rendering: pixelated; flex-shrink: 0; }

  /* ─── HUD ─── */
  .hud {
    width: 290px; min-width: 220px;
    background: var(--panel);
    border-left: 1px solid var(--border);
    display: flex; flex-direction: column;
    padding: 14px 12px; gap: 10px;
    overflow-y: auto; flex-shrink: 0;
  }
  .hud-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px; color: var(--dim);
    letter-spacing: 0.3em; text-transform: uppercase;
    margin-bottom: 2px;
  }
  .hud-value {
    font-family: 'Orbitron', monospace;
    font-size: 22px; font-weight: 700;
    color: var(--accent); text-shadow: var(--glow);
  }
  .hud-timer { color: var(--warn); text-shadow: 0 0 10px #ffb80066; }
  .hud-timer.urgent { color: var(--wrong); animation: blink 0.5s step-end infinite; }
  .hud-timer.frozen { color: var(--pu-freeze); text-shadow: 0 0 12px #00cfffaa; animation: frozenPulse 0.8s ease-in-out infinite; }
  @keyframes blink { 50% { opacity: 0.3; } }
  @keyframes frozenPulse { 0%,100%{opacity:1} 50%{opacity:0.6} }

  .progress-bar-container {
    background: #0a1520; border: 1px solid var(--border);
    height: 8px; position: relative; overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent2), var(--accent));
    transition: width 0.4s ease; box-shadow: 0 0 8px var(--accent);
  }

  /* ─── CATEGORY BADGE ─── */
  .cat-badge {
    display: inline-block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    padding: 2px 8px;
    border: 1px solid currentColor;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  /* ─── POWER-UPS HUD ─── */
  .powerups-row {
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .pu-chip {
    display: flex; align-items: center; gap: 5px;
    background: #0a1520;
    border: 1px solid currentColor;
    padding: 5px 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
    user-select: none;
  }
  .pu-chip:hover { opacity: 0.85; transform: translateY(-1px); }
  .pu-chip:disabled, .pu-chip.empty { opacity: 0.25; cursor: default; }
  .pu-chip .pu-count {
    font-family: 'Orbitron', monospace;
    font-size: 12px; font-weight: 700;
  }
  .pu-freeze { color: var(--pu-freeze); }
  .pu-hint { color: var(--pu-hint); }
  .pu-boost { color: var(--pu-boost); }
  .pu-reveal { color: var(--pu-reveal); }

  /* ─── QUESTION PANEL ─── */
  .question-panel {
    background: #080f17;
    border: 1px solid var(--accent);
    padding: 12px; flex: 1;
    display: flex; flex-direction: column; gap: 8px;
    box-shadow: inset 0 0 20px #00f5ff0a;
    min-height: 0;
  }
  .question-text {
    font-family: 'Rajdhani', sans-serif;
    font-size: 13px; font-weight: 600;
    color: var(--text); line-height: 1.5; min-height: 50px;
  }
  .answer-btn {
    width: 100%;
    background: #0a1520;
    border: 1px solid var(--dim);
    color: var(--text);
    padding: 8px 10px;
    font-family: 'Rajdhani', sans-serif;
    font-size: 12px; font-weight: 600;
    text-align: left; cursor: pointer;
    transition: all 0.15s;
    display: flex; gap: 7px; align-items: flex-start;
  }
  .answer-btn:hover:not(:disabled) { border-color: var(--accent); background: #0d1f30; color: var(--accent); }
  .answer-btn.correct { border-color: var(--correct); background: #001a0d; color: var(--correct); }
  .answer-btn.wrong { border-color: var(--wrong); background: #1a0005; color: var(--wrong); }
  .answer-btn.eliminated { opacity: 0.2; pointer-events: none; text-decoration: line-through; }
  .answer-btn:disabled { cursor: default; }
  .answer-key { font-family: 'Share Tech Mono', monospace; color: var(--accent2); flex-shrink: 0; font-size: 11px; margin-top: 1px; }

  .feedback-msg {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px; text-align: center;
    padding: 5px; min-height: 20px;
  }
  .feedback-msg.correct { color: var(--correct); }
  .feedback-msg.wrong { color: var(--wrong); }
  .fact-box {
    background: #050d14;
    border-left: 3px solid var(--accent2);
    padding: 7px 9px;
    font-size: 11px; color: var(--dim);
    line-height: 1.5; display: none;
  }
  .fact-box.show { display: block; }

  /* ─── MOBILE OVERLAY ─── */
  .q-overlay {
    position: fixed; inset: 0;
    background: #050a0fee;
    z-index: 500;
    display: none;
    align-items: center; justify-content: center;
    padding: 16px;
  }
  .q-overlay.show { display: flex; }
  .q-card {
    background: var(--panel);
    border: 1px solid var(--accent);
    max-width: 500px; width: 100%;
    padding: 20px; box-shadow: var(--glow);
    display: flex; flex-direction: column; gap: 12px;
    max-height: 90vh; overflow-y: auto;
  }

  /* ─── POWER-UP POPUP ─── */
  .pu-popup {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 600;
    background: var(--panel);
    border: 2px solid var(--warn);
    padding: 20px 28px;
    text-align: center;
    box-shadow: 0 0 30px #ffb80066;
    display: none;
    flex-direction: column; gap: 10px;
    animation: popIn 0.3s ease;
  }
  .pu-popup.show { display: flex; }
  @keyframes popIn {
    from { transform: translate(-50%, -50%) scale(0.7); opacity: 0; }
    to { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  }
  .pu-popup-icon { font-size: 36px; }
  .pu-popup-title {
    font-family: 'Orbitron', monospace;
    font-size: 14px; font-weight: 700; color: var(--warn);
  }
  .pu-popup-desc {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px; color: var(--dim);
  }

  /* ─── FINISH SCREEN ─── */
  #finishScreen {
    background: radial-gradient(ellipse at 50% 40%, #0d1a0d 0%, #050a0f 70%);
    gap: 16px; padding: 20px;
  }
  .finish-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(28px, 6vw, 56px); font-weight: 900;
    color: var(--correct); text-shadow: 0 0 20px var(--correct);
    text-align: center;
  }
  .stats-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 12px; width: min(680px, 90vw);
  }
  .stat-card {
    background: var(--panel); border: 1px solid var(--border);
    padding: 12px; text-align: center;
  }
  .stat-val {
    font-family: 'Orbitron', monospace;
    font-size: 22px; font-weight: 700;
    color: var(--accent); text-shadow: var(--glow);
  }

  /* ─── LEADERBOARD ─── */
  .leaderboard {
    width: min(680px, 90vw);
    background: var(--panel); border: 1px solid var(--border); overflow: hidden;
  }
  .lb-header {
    background: #0a1520; padding: 8px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px; letter-spacing: 0.3em; color: var(--dim);
    display: grid; grid-template-columns: 36px 1fr 70px 60px 60px;
  }
  .lb-row {
    padding: 9px 14px;
    display: grid; grid-template-columns: 36px 1fr 70px 60px 60px;
    border-top: 1px solid #ffffff08;
    font-family: 'Share Tech Mono', monospace; font-size: 12px;
    align-items: center; transition: background 0.2s;
  }
  .lb-row:hover { background: #0a1520; }
  .lb-row.highlight { background: #001a20; border-left: 2px solid var(--accent); }
  .lb-row.highlight-new { background: #00120a; border-left: 2px solid var(--correct); animation: newEntry 1s ease; }
  @keyframes newEntry { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:none} }
  .lb-rank { color: var(--accent2); font-size: 10px; }
  .lb-rank.gold { color: #ffd700; }
  .lb-rank.silver { color: #c0c0c0; }
  .lb-rank.bronze { color: #cd7f32; }
  .lb-name { color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .lb-time { color: var(--correct); text-align: right; }
  .lb-score { color: var(--warn); text-align: right; }
  .lb-diff { text-align: right; font-size: 10px; }

  /* ─── FIREBASE STATUS ─── */
  .fb-status {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px; display: flex; align-items: center; gap: 6px;
  }
  .fb-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--dim); }
  .fb-dot.connected { background: var(--correct); box-shadow: 0 0 6px var(--correct); }
  .fb-dot.error { background: var(--wrong); }
  .fb-dot.loading { background: var(--warn); animation: blink 0.8s step-end infinite; }

  /* ─── CATEGORY FILTER ─── */
  .cat-filters { display: flex; gap: 6px; flex-wrap: wrap; }
  .cat-filter-btn {
    background: #0a1520; border: 1px solid var(--dim);
    color: var(--dim); padding: 4px 10px;
    font-family: 'Share Tech Mono', monospace; font-size: 9px;
    letter-spacing: 0.15em; cursor: pointer; text-transform: uppercase;
    transition: all 0.15s;
  }
  .cat-filter-btn.active { border-color: currentColor; }

  /* ─── NOTIFICATION ─── */
  .notif {
    position: fixed; top: 16px; left: 50%; transform: translateX(-50%);
    z-index: 900;
    font-family: 'Share Tech Mono', monospace; font-size: 13px;
    padding: 9px 18px;
    border: 1px solid var(--accent); background: var(--panel);
    color: var(--accent); box-shadow: var(--glow);
    pointer-events: none; opacity: 0; transition: opacity 0.3s;
    white-space: nowrap;
  }
  .notif.show { opacity: 1; }
  .notif.wrong-notif { border-color: var(--wrong); color: var(--wrong); box-shadow: 0 0 12px #ff386088; }
  .notif.pu-notif { border-color: var(--warn); color: var(--warn); box-shadow: 0 0 12px #ffb80088; }

  /* ─── MINI MAP ─── */
  #miniMap { width: 100%; height: 90px; border: 1px solid var(--border); background: #05080f; }

  /* ─── CANVAS WRAPPER ─── */
  #canvasWrapper {
    flex: 1; overflow: auto;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg);
  }

  /* ─── LB SCREEN ─── */
  #lbScreen {
    gap: 14px; padding: 20px;
    background: radial-gradient(ellipse at 50% 20%, #0a0a1f, #050a0f);
  }
  .lb-screen-title {
    font-family: 'Orbitron', monospace; font-size: 26px; font-weight: 900;
    color: var(--accent2); text-shadow: var(--glow2);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 720px) {
    #gameScreen { flex-direction: column; }
    .hud { width: 100%; min-width: 0; border-left: none; border-top: 1px solid var(--border); height: auto; max-height: 52vh; }
    #canvasWrapper { max-height: 48vh; }
    .question-panel { display: none; }
    .q-overlay { display: none; }
    .q-overlay.show { display: flex; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<!-- START SCREEN -->
<div class="screen" id="startScreen">
  <div style="text-align:center;margin-bottom:6px;">
    <div class="logo-title">VOI MAZE</div>
    <div class="logo-sub">blockchain learning // escape protocol v2.0</div>
  </div>
  <canvas id="charPreview" width="80" height="100" style="image-rendering:pixelated;"></canvas>
  <div class="start-form">
    <input class="cyber-input" id="playerName" placeholder="ENTER CALLSIGN" maxlength="20" autocomplete="off">
    <div>
      <div class="hud-label" style="margin-bottom:6px;">DIFFICULTY</div>
      <div class="difficulty-row">
        <button class="diff-btn active-normal" data-diff="normal" id="diffNormal">NORMAL</button>
        <button class="diff-btn" data-diff="easy" id="diffEasy">EASY</button>
        <button class="diff-btn" data-diff="hard" id="diffHard">HARD</button>
      </div>
    </div>
    <div class="divider"></div>
    <button class="cyber-btn" id="startBtn">INITIALIZE SEQUENCE</button>
    <button class="cyber-btn secondary" id="lbBtn">VIEW LEADERBOARD</button>
  </div>
  <div style="display:flex;align-items:center;gap:8px;margin-top:6px;">
    <div class="fb-dot" id="fbDotStart"></div>
    <span style="font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);" id="fbStatusStart">CHECKING CONNECTION...</span>
  </div>
  <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);margin-top:4px;text-align:center;line-height:1.8;">
    ANSWER 20 QUESTIONS TO ESCAPE · COLLECT POWER-UPS IN THE MAZE
  </div>
</div>

<!-- GAME SCREEN -->
<div class="screen hidden" id="gameScreen">
  <div id="canvasWrapper">
    <canvas id="gameCanvas"></canvas>
  </div>
  <div class="hud">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;">
      <div>
        <div class="hud-label">OPERATIVE</div>
        <div style="font-family:'Orbitron',monospace;font-size:14px;color:var(--text);font-weight:700;" id="hudName">—</div>
      </div>
      <div style="text-align:right;">
        <div class="hud-label">DIFFICULTY</div>
        <div style="font-family:'Share Tech Mono',monospace;font-size:11px;" id="hudDiff">—</div>
      </div>
    </div>
    <div>
      <div class="hud-label">ELAPSED TIME</div>
      <div class="hud-value hud-timer" id="hudTimer">00:00</div>
    </div>
    <div>
      <div class="hud-label">NODES UNLOCKED <span id="hudQCount" style="color:var(--accent)">0</span>/20</div>
      <div class="progress-bar-container">
        <div class="progress-bar-fill" id="hudProgress" style="width:0%"></div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
      <div>
        <div class="hud-label">ACCURACY</div>
        <div class="hud-value" id="hudAccuracy" style="font-size:18px;">—</div>
      </div>
      <div>
        <div class="hud-label">STREAK 🔥</div>
        <div class="hud-value" id="hudStreak" style="font-size:18px;color:var(--warn);">0</div>
      </div>
    </div>
    <div>
      <div class="hud-label">POWER-UPS</div>
      <div class="powerups-row" id="powerupsRow">
        <button class="pu-chip pu-freeze" id="puFreeze" title="TIME FREEZE — Pause timer for 15s">
          ❄️ <span class="pu-count" id="puFreezeCount">0</span>
        </button>
        <button class="pu-chip pu-hint" id="puHint" title="HINT — Eliminate 2 wrong answers">
          💡 <span class="pu-count" id="puHintCount">0</span>
        </button>
        <button class="pu-chip pu-boost" id="puBoost" title="BOOST — Pass through 1 wall">
          ⚡ <span class="pu-count" id="puBoostCount">0</span>
        </button>
        <button class="pu-chip pu-reveal" id="puReveal" title="REVEAL — Show full map for 5s">
          👁️ <span class="pu-count" id="puRevealCount">0</span>
        </button>
      </div>
    </div>
    <div>
      <div class="hud-label">MINI MAP</div>
      <canvas id="miniMap"></canvas>
    </div>
    <div class="question-panel" id="questionPanel">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div class="hud-label">ACTIVE CHALLENGE</div>
        <div id="qCatBadge" class="cat-badge" style="display:none;"></div>
      </div>
      <div class="question-text" id="questionText">Approach a glowing node to receive a challenge.</div>
      <div id="answersContainer"></div>
      <div class="feedback-msg" id="feedbackMsg"></div>
      <div class="fact-box" id="factBox"></div>
    </div>
  </div>
</div>

<!-- MOBILE QUESTION OVERLAY -->

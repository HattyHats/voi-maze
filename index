// ── MAZE GENERATION ─────────────────────────────────────────────
const MAZE_W = 15, MAZE_H = 15, CELL = 40;

function generateMaze(w, h) {
  const visited = Array.from({length:h}, () => new Array(w).fill(false));
  const walls = Array.from({length:h}, () => Array.from({length:w}, () => ({right:true,bottom:true})));
  function carve(x, y) {
    visited[y][x] = true;
    const dirs = [{dx:1,dy:0},{dx:-1,dy:0},{dx:0,dy:1},{dx:0,dy:-1}].sort(() => Math.random()-0.5);
    for (const {dx,dy} of dirs) {
      const nx=x+dx, ny=y+dy;
      if (nx>=0&&nx<w&&ny>=0&&ny<h&&!visited[ny][nx]) {
        if (dx===1) walls[y][x].right=false;
        if (dx===-1) walls[y][nx].right=false;
        if (dy===1) walls[y][x].bottom=false;
        if (dy===-1) walls[ny][x].bottom=false;
        carve(nx,ny);
      }
    }
  }
  carve(0,0);
  return walls;
}

function bfsOrder(walls) {
  const visited = Array.from({length:MAZE_H}, ()=>new Array(MAZE_W).fill(false));
  const queue = [{x:0,y:0}]; visited[0][0]=true;
  const order = [];
  while(queue.length) {
    const {x,y} = queue.shift();
    order.push({x,y});
    const w = walls[y][x];
    const moves = [
      {nx:x+1,ny:y,ok:!w.right},
      {nx:x-1,ny:y,ok:x>0&&!walls[y][x-1].right},
      {nx:x,ny:y+1,ok:!w.bottom},
      {nx:x,ny:y-1,ok:y>0&&!walls[y-1][x].bottom}
    ];
    for (const {nx,ny,ok} of moves) {
      if (ok&&nx>=0&&nx<MAZE_W&&ny>=0&&ny<MAZE_H&&!visited[ny][nx]) {
        visited[ny][nx]=true; queue.push({x:nx,y:ny});
      }
    }
  }
  return order;
}

function placeNodes(walls) {
  const order = bfsOrder(walls);
  const nodes = [];
  const step = Math.floor(order.length / 21);
  for (let i=1; i<=20; i++) {
    const cell = order[Math.min(i*step, order.length-1)];
    nodes.push({x:cell.x, y:cell.y, answered:false, qIdx:i-1, isExit: i===20});
  }
  return nodes;
}

// Place power-ups randomly in the maze (not on nodes or start)
function placePowerups(walls, nodes) {
  const nodeSet = new Set(nodes.map(n=>`${n.x},${n.y}`));
  nodeSet.add('0,0');
  const order = bfsOrder(walls);
  const candidates = order.filter(c => !nodeSet.has(`${c.x},${c.y}`));
  const shuffled = candidates.sort(() => Math.random()-0.5);

  const types = ['freeze','hint','boost','reveal'];
  const powerups = [];
  const count = { easy:6, normal:4, hard:2 }[state.difficulty] || 4;

  for (let i=0; i<Math.min(count, shuffled.length); i++) {
    powerups.push({
      x: shuffled[i].x, y: shuffled[i].y,
      type: types[i % types.length],
      collected: false,
    });
  }
  return powerups;
}


let allLeaderboardEntries = [];

async function initFirebase() {
  try {
    // Only attempt if config looks real
    if (!FIREBASE_CONFIG.databaseURL || FIREBASE_CONFIG.databaseURL.includes('PASTE')) {
      setFbStatus('all', 'LOCAL MODE (no Firebase config)', 'dim');
      return;
    }
    setFbStatus('all', 'CONNECTING...', 'loading');

    // Dynamically load Firebase SDK
    const { initializeApp } = await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js');
    const { getDatabase, ref, push, onValue, query, orderByChild, limitToLast }
      = await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js');

    const app = initializeApp(FIREBASE_CONFIG);
    db = getDatabase(app);
    fbConnected = true;

    // Store Firebase refs globally for use later
    window._fbRef = ref;
    window._fbPush = push;
    window._fbOnValue = onValue;
    window._fbQuery = query;
    window._fbOrderByChild = orderByChild;
    window._fbLimitToLast = limitToLast;

    setFbStatus('all', 'GLOBAL LEADERBOARD ACTIVE', 'connected');

    // Subscribe to leaderboard
    const lbRef = query(ref(db, 'leaderboard'), orderByChild('score'), limitToLast(100));
    onValue(lbRef, snap => {
      const data = snap.val() || {};
      allLeaderboardEntries = Object.values(data);
      allLeaderboardEntries.sort((a, b) => b.accuracy - a.accuracy || a.time - b.time);
    });

  } catch (e) {
    console.warn('Firebase init failed:', e);
    setFbStatus('all', 'LOCAL MODE (Firebase unavailable)', 'error');
  }
}

function setFbStatus(target, msg, dotState) {

  ctx.fillStyle='#2a2a3a';
  ctx.fillRect(px-12*s,py-2*s,4*s,10*s);
  ctx.fillRect(px+8*s,py-2*s,4*s,10*s);
  ctx.fillStyle='#111';
  ctx.fillRect(px-11*s,py,2*s,2*s);
  ctx.fillRect(px+10*s,py,2*s,2*s);
  ctx.fillStyle='#c8a882'; ctx.fillRect(px-6*s,py-18*s,12*s,12*s);
  ctx.fillStyle='#777';
  ctx.fillRect(px-7*s,py-20*s,14*s,5*s);
  ctx.fillRect(px-10*s,py-17*s,20*s,2*s);
  ctx.fillStyle='#222';
  ctx.fillRect(px-4*s,py-14*s,2*s,2*s);
  ctx.fillRect(px+2*s,py-14*s,2*s,2*s);
  ctx.fillStyle='#333';
  ctx.fillRect(px-8*s,py+10*s,6*s,8*s);
  ctx.fillRect(px+2*s,py+10*s,6*s,8*s);
}

// ── TOUCH / DPAD ──────────────────────────────────────────────────
let touchStart=null;
canvas.addEventListener('touchstart',e=>{ touchStart={x:e.touches[0].clientX,y:e.touches[0].clientY}; e.preventDefault(); },{passive:false});
canvas.addEventListener('touchend',e=>{
  if(!touchStart) return;
  const dx=e.changedTouches[0].clientX-touchStart.x;
  const dy=e.changedTouches[0].clientY-touchStart.y;
  const adx=Math.abs(dx),ady=Math.abs(dy);
  if(Math.max(adx,ady)<10) return;
  if(adx>ady) tryMove(dx>0?1:-1,0); else tryMove(0,dy>0?1:-1);
  touchStart=null; e.preventDefault();
},{passive:false});

function addDpad() {
  if(document.getElementById('dpad')) return;
  const dpad=document.createElement('div');
  dpad.id='dpad';
  dpad.style.cssText=`position:fixed;bottom:20px;right:20px;display:grid;grid-template-columns:44px 44px 44px;grid-template-rows:44px 44px 44px;gap:4px;z-index:200;`;
  [{dx:0,dy:-1,pos:'1/2',label:'↑'},{dx:-1,dy:0,pos:'2/1',label:'←'},{dx:1,dy:0,pos:'2/3',label:'→'},{dx:0,dy:1,pos:'3/2',label:'↓'}].forEach(({dx,dy,pos,label})=>{
    const b=document.createElement('button');
    b.textContent=label;
    b.style.cssText=`grid-column:${pos.split('/')[1]};grid-row:${pos.split('/')[0]};background:#080f17;border:1px solid #00f5ff44;color:#00f5ff;font-size:20px;cursor:pointer;border-radius:4px;-webkit-tap-highlight-color:transparent;`;
    b.addEventListener('touchstart',e=>{tryMove(dx,dy);e.preventDefault();},{passive:false});
    b.addEventListener('click',()=>tryMove(dx,dy));
    dpad.appendChild(b);
  });
  document.body.appendChild(dpad);
}

// ── KEYBOARD ──────────────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  if(e.key in KEY_MAP) {
    state.keys[e.key]=true;
    if(!state.questionActive){const dir=KEY_MAP[e.key];tryMove(dir.dx,dir.dy);state.lastMoveTime=Date.now();}
    e.preventDefault();
  }
  // Number keys for power-ups during question
  if(e.key==='1') usePowerup('freeze');
  if(e.key==='2') usePowerup('hint');
  if(e.key==='3') usePowerup('boost');
  if(e.key==='4') usePowerup('reveal');
});
document.addEventListener('keyup',e=>{ state.keys[e.key]=false; });

// ── DIFFICULTY BUTTONS ────────────────────────────────────────────
document.querySelectorAll('.diff-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const d=btn.dataset.diff;
    state.difficulty=d;
    document.querySelectorAll('.diff-btn').forEach(b=>b.className='diff-btn');
    btn.className=`diff-btn active-${d}`;
  });
});

// ── POWER-UP BUTTON BINDINGS ──────────────────────────────────────
document.getElementById('puFreeze').addEventListener('click',()=>usePowerup('freeze'));
document.getElementById('puHint').addEventListener('click',()=>usePowerup('hint'));
document.getElementById('puBoost').addEventListener('click',()=>usePowerup('boost'));
document.getElementById('puReveal').addEventListener('click',()=>usePowerup('reveal'));

// ── UI BINDINGS ───────────────────────────────────────────────────
document.getElementById('startBtn').addEventListener('click',async ()=>{
  const name=document.getElementById('playerName').value.trim()||'ANON';
  await initGame(name, state.difficulty);
  if(window.innerWidth<=720) addDpad();
});
document.getElementById('playerName').addEventListener('keydown',e=>{ if(e.key==='Enter') document.getElementById('startBtn').click(); });

document.getElementById('lbBtn').addEventListener('click',()=>{
  const lb=getLeaderboard('all');
  renderLeaderboard('lbScreenBody',lb,null);
  setFbStatus('Lb', fbConnected?'GLOBAL LEADERBOARD':'LOCAL LEADERBOARD', fbConnected?'connected':'dim');
  showScreen('lb');
});
document.getElementById('lbBtnFinish').addEventListener('click',()=>{
  const lb=getLeaderboard('all');
  renderLeaderboard('lbScreenBody',lb,null);
  showScreen('lb');
});
document.getElementById('lbBackBtn').addEventListener('click',()=>showScreen('start'));

// Leaderboard filter buttons
document.getElementById('lbFilters').addEventListener('click',e=>{
  const btn=e.target.closest('[data-diff]');
  if(!btn) return;
  document.querySelectorAll('#lbFilters .cat-filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const lb=getLeaderboard(btn.dataset.diff);
  renderLeaderboard('lbScreenBody',lb,null);
});

document.getElementById('replayBtn').addEventListener('click',()=>{
  showScreen('start');
  clearInterval(state.timerInterval);
  cancelAnimationFrame(state.animFrame);
});

document.getElementById('shareBtn').addEventListener('click',()=>{
  const acc=Math.round(state.correct/20*100);
  const diff=state.difficulty.toUpperCase();
  const txt=`🌐 VOI MAZE [${diff}] | ${state.playerName} | Time: ${formatTime(state.timer)} | Accuracy: ${acc}% | Streak: ${state.maxStreak}x | voi.network`;
  navigator.clipboard.writeText(txt).then(()=>showNotif('RESULT COPIED!'));
});

window.addEventListener('resize',()=>{ if(state.screen==='game') resizeCanvas(); });

// ── BOOT ─────────────────────────────────────────────────────────
(async()=>{
  drawCharPreview();
  showScreen('start');
  await loadQuestions();
  await initFirebase();
})();
</script>
</body>
</html>

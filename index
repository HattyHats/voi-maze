  ids.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.className = 'fb-dot ' + dotState;
  });
  Object.entries(msgIds).forEach(([k,id]) => {
    const el = document.getElementById(id);
    if (el && (target === 'all')) el.textContent = msg;
  });
}

async function saveToFirebase(entry) {
  if (!fbConnected || !db) {
    saveToLocalStorage(entry);
    return;
  }
  try {
    await window._fbPush(window._fbRef(db, 'leaderboard'), entry);
    setFbStatus('Finish', 'SAVED TO GLOBAL LEADERBOARD ✓', 'connected');
  } catch (e) {
    console.warn('Firebase save failed, falling back to localStorage:', e);
    saveToLocalStorage(entry);
    setFbStatus('Finish', 'SAVED LOCALLY (Firebase write failed)', 'error');
  }
}


function resizeCanvas() {
  const wrapper = document.getElementById('canvasWrapper');
  const maxW = wrapper.clientWidth, maxH = wrapper.clientHeight;
  const dw = MAZE_W*CELL+2, dh = MAZE_H*CELL+2;
  const scale = Math.min(maxW/dw, maxH/dh, 1);
  canvas.width = dw; canvas.height = dh;
  canvas.style.width = (dw*scale)+'px';
  canvas.style.height = (dh*scale)+'px';
}

// ── DRAWING ──────────────────────────────────────────────────────
let time = 0;

const PU_ICONS = { freeze:'❄️', hint:'💡', boost:'⚡', reveal:'👁️' };
const PU_COLORS = { freeze:'#00cfff', hint:'#ffe600', boost:'#ff6b35', reveal:'#b400ff' };

function drawMaze() {
  ctx.fillStyle = '#050a0f';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  const walls = state.maze;
  const vis = state.visibleCells;
  const fullReveal = state.revealed && Date.now() < state.revealEnd;

  // Floors
  for (let y=0; y<MAZE_H; y++) {
    for (let x=0; x<MAZE_W; x++) {
      const key = `${x},${y}`;
      if (!vis.has(key) && !fullReveal) { continue; }
      const cx=x*CELL+1, cy=y*CELL+1;
      ctx.fillStyle = vis.has(key) ? '#090f1a' : '#060c12';
      ctx.fillRect(cx,cy,CELL,CELL);
      ctx.strokeStyle = '#0a1520'; ctx.lineWidth=0.5;
      ctx.strokeRect(cx,cy,CELL,CELL);
    }
  }

  // Walls
  for (let y=0; y<MAZE_H; y++) {
    for (let x=0; x<MAZE_W; x++) {
      const key = `${x},${y}`;
      if (!vis.has(key) && !fullReveal) continue;
      const cx=x*CELL+1, cy=y*CELL+1;
      const w=walls[y][x];
      const wallCol = state.frozen ? '#00cfff' : '#00f5ff';
      if (y===0) drawWall(cx,cy,cx+CELL,cy,wallCol);
      if (x===0) drawWall(cx,cy,cx,cy+CELL,wallCol);
      if (w.right) drawWall(cx+CELL,cy,cx+CELL,cy+CELL,wallCol);
      if (w.bottom) drawWall(cx,cy+CELL,cx+CELL,cy+CELL,wallCol);
    }
  }

  // Power-ups
  for (const pu of state.powerups) {
    if (pu.collected) continue;
    const key=`${pu.x},${pu.y}`;
    if (!vis.has(key) && !fullReveal) continue;
    const px=pu.x*CELL+CELL/2+1, py=pu.y*CELL+CELL/2+1;
    const bob = Math.sin(time*0.08+pu.x+pu.y)*3;
    const col=PU_COLORS[pu.type];
    ctx.save();
    ctx.shadowColor=col; ctx.shadowBlur=10+5*Math.abs(Math.sin(time*0.05));
    ctx.font=`${14+bob}px serif`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText(PU_ICONS[pu.type], px, py+bob);
    ctx.restore();

    // Ring
    ctx.beginPath();
    ctx.arc(px,py,14+bob,0,Math.PI*2);
    ctx.strokeStyle=col+'55'; ctx.lineWidth=1; ctx.stroke();
  }

  // Question nodes
  for (const node of state.nodes) {
    const key=`${node.x},${node.y}`;
    if (!vis.has(key) && !fullReveal) continue;
    const nx=node.x*CELL+CELL/2+1, ny=node.y*CELL+CELL/2+1;

    if (node.answered) {
      ctx.beginPath();
      ctx.arc(nx,ny,5,0,Math.PI*2);
      ctx.fillStyle='#00ff9d'; ctx.fill();
    } else {
      const pulse=0.7+0.3*Math.sin(time*0.06+node.x+node.y);
      const col=node.isExit?'#ff006e':'#7b00ff';
      ctx.save();
      ctx.shadowColor=col; ctx.shadowBlur=12*pulse;
      ctx.beginPath(); ctx.arc(nx,ny,7*pulse,0,Math.PI*2);
      ctx.fillStyle=col; ctx.fill();
      ctx.restore();
      ctx.beginPath(); ctx.arc(nx,ny,10+3*pulse,0,Math.PI*2);
      ctx.strokeStyle=col+'66'; ctx.lineWidth=1; ctx.stroke();
    }
  }

  drawPlayer();
}

function drawWall(x1,y1,x2,y2,col='#00f5ff') {
  ctx.save();
  ctx.shadowColor=col; ctx.shadowBlur=5;
  ctx.strokeStyle=col; ctx.lineWidth=2;
  ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
  ctx.restore();
}

function drawPlayer() {
  const {x,y}=state.player;
  const px=x*CELL+CELL/2+1, py=y*CELL+CELL/2+1;
  const s=1.5;
  ctx.save();

  // Boost glow
  if (state.boostActive) { ctx.shadowColor='#ff6b35'; ctx.shadowBlur=16; }
  else if (state.frozen) { ctx.shadowColor='#00cfff'; ctx.shadowBlur=10; }
  else { ctx.shadowColor='#00f5ff'; ctx.shadowBlur=8; }

  ctx.fillStyle='#888';
  ctx.fillRect(px-5*s,py-4*s,10*s,10*s);
  ctx.fillStyle='#2a2a3a';
  ctx.fillRect(px-8*s,py-3*s,3*s,7*s);
  ctx.fillRect(px+5*s,py-3*s,3*s,7*s);
  ctx.fillStyle='#111';
  ctx.fillRect(px-7*s,py-2*s,2*s,2*s);
  ctx.fillRect(px+6*s,py-2*s,2*s,2*s);
  ctx.fillStyle='#c8a882';
  ctx.fillRect(px-4*s,py-14*s,8*s,8*s);
  ctx.fillStyle='#777';
  ctx.fillRect(px-5*s,py-16*s,10*s,4*s);
  ctx.fillRect(px-7*s,py-14*s,14*s,2*s);
  ctx.fillStyle='#222';
  ctx.fillRect(px-3*s,py-12*s,2*s,2*s);
  ctx.fillRect(px+1*s,py-12*s,2*s,2*s);
  ctx.fillStyle='#333';
  ctx.fillRect(px-5*s,py+6*s,4*s,6*s);
  ctx.fillRect(px+1*s,py+6*s,4*s,6*s);
  ctx.restore();
}

function updateVisibility() {
  const {x,y}=state.player;
  const r = { easy:4, normal:3, hard:2 }[state.difficulty] || 3;
  for (let dy=-r; dy<=r; dy++) {
    for (let dx=-r; dx<=r; dx++) {
      const nx=x+dx, ny=y+dy;
      if (nx>=0&&nx<MAZE_W&&ny>=0&&ny<MAZE_H&&dx*dx+dy*dy<=r*r) {
        state.visibleCells.add(`${nx},${ny}`);
      }
    }
  }
}

function drawMiniMap() {
  const mc=miniMapCanvas, mw=mc.width, mh=mc.height;
  miniCtx.fillStyle='#050a0f'; miniCtx.fillRect(0,0,mw,mh);
  const cw=mw/MAZE_W, ch=mh/MAZE_H;
  const fullReveal = state.revealed && Date.now()<state.revealEnd;

  for (let y=0; y<MAZE_H; y++) {
    for (let x=0; x<MAZE_W; x++) {
      if (!state.visibleCells.has(`${x},${y}`) && !fullReveal) continue;
      miniCtx.fillStyle='#0d1f30';
      miniCtx.fillRect(x*cw,y*ch,cw-0.5,ch-0.5);
    }
  }
  for (const pu of state.powerups) {
    if (pu.collected) continue;
    if (!state.visibleCells.has(`${pu.x},${pu.y}`) && !fullReveal) continue;
    miniCtx.fillStyle=PU_COLORS[pu.type];
    miniCtx.fillRect(pu.x*cw+cw*0.2,pu.y*ch+ch*0.2,cw*0.6,ch*0.6);
  }
  for (const node of state.nodes) {
    if (!state.visibleCells.has(`${node.x},${node.y}`) && !fullReveal) continue;
    miniCtx.fillStyle=node.answered?'#00ff9d':(node.isExit?'#ff006e':'#7b00ff');
    miniCtx.fillRect(node.x*cw+cw*0.25,node.y*ch+ch*0.25,cw*0.5,ch*0.5);
  }
  miniCtx.fillStyle='#00f5ff';
  miniCtx.fillRect(state.player.x*cw+cw*0.15,state.player.y*ch+ch*0.15,cw*0.7,ch*0.7);
}

// ── MOVEMENT ─────────────────────────────────────────────────────
const KEY_MAP = {
  ArrowUp:{dx:0,dy:-1}, ArrowDown:{dx:0,dy:1},
  ArrowLeft:{dx:-1,dy:0}, ArrowRight:{dx:1,dy:0},
  w:{dx:0,dy:-1}, s:{dx:0,dy:1}, a:{dx:-1,dy:0}, d:{dx:1,dy:0},
  W:{dx:0,dy:-1}, S:{dx:0,dy:1}, A:{dx:-1,dy:0}, D:{dx:1,dy:0},
};

function canMove(x,y,dx,dy) {
  if (state.boostActive) return true; // pass through walls
  const w=state.maze;
  if (dx===1) return !w[y][x].right;
  if (dx===-1) return x>0&&!w[y][x-1].right;
  if (dy===1) return !w[y][x].bottom;
  if (dy===-1) return y>0&&!w[y-1][x].bottom;
  return false;
}

function tryMove(dx,dy) {
  if (state.questionActive||state.finished) return;
  const {x,y}=state.player;
  const nx=x+dx, ny=y+dy;
  if (nx<0||nx>=MAZE_W||ny<0||ny>=MAZE_H) return;
  if (!canMove(x,y,dx,dy)) return;

  if (state.boostActive) {
    state.boostActive=false;
    showNotif('⚡ BOOST USED!', false);
    updatePUDisplay();
  }

  state.player.x=nx; state.player.y=ny;
  updateVisibility();
  checkPowerupPickup();
  checkNode();
}

function checkPowerupPickup() {
  const {x,y}=state.player;
  const pu=state.powerups.find(p=>p.x===x&&p.y===y&&!p.collected);
  if (!pu) return;
  pu.collected=true;
  state.powerupInventory[pu.type]++;
  updatePUDisplay();
  showPUPopup(pu.type);
}

function checkNode() {
  const {x,y}=state.player;
  const node=state.nodes.find(n=>n.x===x&&n.y===y&&!n.answered);
  if (!node) return;
  state.activeNode=node;
  state.questionActive=true;
  state.activeHintEliminated=[];
  showQuestion(node.qIdx);
}

// ── POWER-UPS ────────────────────────────────────────────────────
function usePowerup(type) {
  if (state.powerupInventory[type] <= 0) return;
  if (!state.questionActive && (type==='hint')) { showNotif('Use HINT when at a question node', true); return; }

  state.powerupInventory[type]--;
  updatePUDisplay();

  switch(type) {
    case 'freeze':
      state.frozen=true;
      state.freezeEnd=Date.now()+15000;
      showNotif('❄️ TIME FROZEN for 15 seconds!');
      setTimeout(()=>{ state.frozen=false; showNotif('❄️ Time freeze expired'); }, 15000);
      break;

    case 'hint':
      if (!state.questionActive) break;
      const q=state.questions[state.activeNode.qIdx];
      const wrongIdxs=q.opts.map((_,i)=>i).filter(i=>i!==q.a&&!state.activeHintEliminated.includes(i));
      const toElim=wrongIdxs.sort(()=>Math.random()-0.5).slice(0,2);
      toElim.forEach(i=>state.activeHintEliminated.push(i));
      applyHintElimination(toElim);
      showNotif('💡 2 wrong answers eliminated!');
      break;

    case 'boost':
      state.boostActive=true;
      showNotif('⚡ WALL BOOST active — pass through next wall!');
      break;

    case 'reveal':
      state.revealed=true;
      state.revealEnd=Date.now()+5000;
      showNotif('👁️ FULL MAP revealed for 5 seconds!');
      setTimeout(()=>{ state.revealed=false; }, 5000);
      break;
  }
}

function applyHintElimination(indices) {
  const isMobile=window.innerWidth<=720;
  const ansEl=isMobile?document.getElementById('qOverlayAnswers'):document.getElementById('answersContainer');
  if (!ansEl) return;
  const btns=ansEl.querySelectorAll('.answer-btn');
  indices.forEach(i=>{ if(btns[i]) btns[i].classList.add('eliminated'); });
}

function updatePUDisplay() {
  const inv=state.powerupInventory;
  ['freeze','hint','boost','reveal'].forEach(t=>{
    const countEl=document.getElementById('pu'+t.charAt(0).toUpperCase()+t.slice(1)+'Count');
    const chipEl=document.getElementById('pu'+t.charAt(0).toUpperCase()+t.slice(1));
    if(countEl) countEl.textContent=inv[t];
    if(chipEl) { chipEl.disabled=inv[t]===0; chipEl.classList.toggle('empty',inv[t]===0); }
  });
}

function showPUPopup(type) {
  const popup=document.getElementById('puPopup');
  const names={freeze:'TIME FREEZE',hint:'HINT CHIP',boost:'WALL BOOST',reveal:'MAP REVEAL'};
  const descs={freeze:'Pauses the timer for 15 seconds',hint:'Eliminates 2 wrong answers',boost:'Pass through one wall',reveal:'See full map for 5 seconds'};
  document.getElementById('puPopupIcon').textContent=PU_ICONS[type];
  document.getElementById('puPopupTitle').textContent=names[type]+' COLLECTED';
  document.getElementById('puPopupDesc').textContent=descs[type];
  popup.classList.add('show');
  setTimeout(()=>popup.classList.remove('show'), 2200);
}

// ── QUESTIONS ────────────────────────────────────────────────────
const DIFF_CONFIG = {
  easy:   { penalty:5,  pool:[1,2] },
  normal: { penalty:10, pool:[1,2,3] },
  hard:   { penalty:20, pool:[2,3] },
};

function getQuestionsForDifficulty() {
  const conf=DIFF_CONFIG[state.difficulty];
  let pool=QUESTIONS.filter(q=>conf.pool.includes(q.difficulty));
  if (pool.length < 20) pool=[...QUESTIONS]; // fallback to all
  return pool.sort(()=>Math.random()-0.5).slice(0,20);
}

function showQuestion(qIdx) {
  const q=state.questions[qIdx];
  if (!q) return;
  const isMobile=window.innerWidth<=720;
  const textEl=isMobile?document.getElementById('qOverlayText'):document.getElementById('questionText');
  const ansEl=isMobile?document.getElementById('qOverlayAnswers'):document.getElementById('answersContainer');
  const fbEl=isMobile?document.getElementById('qOverlayFeedback'):document.getElementById('feedbackMsg');
  const factEl=isMobile?document.getElementById('qOverlayFact'):document.getElementById('factBox');

  textEl.textContent=`[Q${qIdx+1}/20] ${q.q}`;
  fbEl.textContent=''; fbEl.className='feedback-msg';
  factEl.textContent=''; factEl.className='fact-box';

  // Category badge
  const cat=CATEGORIES[q.category]||{label:q.category,color:'#00f5ff'};
  const badgeEl=isMobile?document.getElementById('qOverlayCatBadge'):document.getElementById('qCatBadge');
  if (badgeEl) {
    badgeEl.textContent=cat.label;
    badgeEl.style.color=cat.color;
    badgeEl.style.display='inline-block';
  }

  const keys=['A','B','C','D'];
  ansEl.innerHTML='';
  q.opts.forEach((opt,i)=>{
    const btn=document.createElement('button');
    btn.className='answer-btn';
    btn.innerHTML=`<span class="answer-key">${keys[i]}</span><span>${opt}</span>`;
    if (state.activeHintEliminated.includes(i)) btn.classList.add('eliminated');
    btn.addEventListener('click',()=>handleAnswer(i,qIdx,btn,ansEl,fbEl,factEl,isMobile));
    ansEl.appendChild(btn);
  });

  if (isMobile) document.getElementById('qOverlay').classList.add('show');
}

function handleAnswer(chosen,qIdx,clickedBtn,ansEl,fbEl,factEl,isMobile) {
  const q=state.questions[qIdx];
  const btns=ansEl.querySelectorAll('.answer-btn');
  btns.forEach(b=>b.disabled=true);

  const isCorrect=chosen===q.a;
  btns[q.a].classList.add('correct');
  if (!isCorrect) {
    clickedBtn.classList.add('wrong');
    state.wrong++;
    state.streak=0;
    const penalty=DIFF_CONFIG[state.difficulty].penalty;
    state.timer+=penalty;
    showNotif(`✗ INCORRECT — +${penalty}s PENALTY`, true);
  } else {
    state.correct++;
    state.streak++;
    if (state.streak>state.maxStreak) state.maxStreak=state.streak;
    showNotif(state.streak>2?`✓ CORRECT — ${state.streak}x STREAK 🔥!`:'✓ CORRECT — NODE UNLOCKED!', false);
  }

  state.totalAnswered++;
  updateHUD();
  fbEl.textContent=isCorrect?'✓ CORRECT — PATH UNLOCKED':'✗ INCORRECT — PENALTY APPLIED';
  fbEl.className='feedback-msg '+(isCorrect?'correct':'wrong');
  factEl.textContent='◈ '+q.fact;
  factEl.className='fact-box show';

  const delay=isCorrect?1800:2500;
  setTimeout(()=>{
    state.activeNode.answered=true;
    state.questionActive=false;
    state.activeHintEliminated=[];
    if (isMobile) document.getElementById('qOverlay').classList.remove('show');
    // Reset desktop panel hint
    const badgeEl=document.getElementById('qCatBadge');
    if(badgeEl) badgeEl.style.display='none';
    updateHUD();
    if (state.activeNode.isExit) finishGame();
  }, delay);
}

// ── HUD ──────────────────────────────────────────────────────────
function updateHUD() {
  const answered=state.nodes.filter(n=>n.answered).length;
  document.getElementById('hudQCount').textContent=answered;
  document.getElementById('hudProgress').style.width=(answered/20*100)+'%';
  const acc=state.totalAnswered>0?Math.round(state.correct/state.totalAnswered*100)+'%':'—';
  document.getElementById('hudAccuracy').textContent=acc;
  document.getElementById('hudStreak').textContent=state.streak;
  updatePUDisplay();
}

function formatTime(secs) {
  const m=Math.floor(secs/60).toString().padStart(2,'0');
  const s=(secs%60).toString().padStart(2,'0');
  return `${m}:${s}`;
}

function startTimer() {
  state.timerInterval=setInterval(()=>{
    if (state.frozen && Date.now()<state.freezeEnd) return; // frozen!
    state.timer++;
    const el=document.getElementById('hudTimer');
    el.textContent=formatTime(state.timer);
    if (state.frozen) el.className='hud-value hud-timer frozen';
    else if (state.timer>300) el.className='hud-value hud-timer urgent';
    else el.className='hud-value hud-timer';
  },1000);
}

// ── NOTIFICATION ─────────────────────────────────────────────────
let notifTimeout;
function showNotif(msg, isWrong=false, isPU=false) {
  const el=document.getElementById('notif');
  el.textContent=msg;
  el.className='notif show'+(isWrong?' wrong-notif':isPU?' pu-notif':'');
  clearTimeout(notifTimeout);
  notifTimeout=setTimeout(()=>el.className='notif',2200);
}

// ── GAME LOOP ─────────────────────────────────────────────────────
function gameLoop() {
  time++;
  const now=Date.now();
  if (now-state.lastMoveTime>150&&!state.questionActive) {
    for (const [key,dir] of Object.entries(KEY_MAP)) {
      if (state.keys[key]) { tryMove(dir.dx,dir.dy); state.lastMoveTime=now; break; }
    }
  }
  drawMaze();
  drawMiniMap();
  state.animFrame=requestAnimationFrame(gameLoop);
}

// ── INIT GAME ─────────────────────────────────────────────────────
async function initGame(name, difficulty) {
  state.playerName=name;
  state.difficulty=difficulty;
  state.maze=generateMaze(MAZE_W,MAZE_H);
  state.questions=getQuestionsForDifficulty();
  state.nodes=placeNodes(state.maze);
  state.powerups=placePowerups(state.maze, state.nodes);
  state.player={x:0,y:0};
  state.timer=0; state.correct=0; state.wrong=0; state.totalAnswered=0;
  state.streak=0; state.maxStreak=0;
  state.activeNode=null; state.questionActive=false; state.finished=false;
  state.visibleCells=new Set();
  state.keys={}; state.lastMoveTime=0;
  state.powerupInventory={freeze:0,hint:0,boost:0,reveal:0};
  state.frozen=false; state.boostActive=false; state.revealed=false;
  state.activeHintEliminated=[];

  updateVisibility();

  const diffLabels={easy:'EASY',normal:'NORMAL',hard:'HARD'};
  const diffColors={easy:'var(--correct)',normal:'var(--accent)',hard:'var(--wrong)'};
  document.getElementById('hudName').textContent=name.toUpperCase();
  document.getElementById('hudDiff').textContent=diffLabels[difficulty];
  document.getElementById('hudDiff').style.color=diffColors[difficulty];

  showScreen('game');
  resizeCanvas();
  startTimer();
  if (state.animFrame) cancelAnimationFrame(state.animFrame);
  gameLoop();

  document.getElementById('questionText').textContent='Approach a glowing node to receive a challenge.';
  document.getElementById('answersContainer').innerHTML='';
  document.getElementById('feedbackMsg').textContent='';
  document.getElementById('factBox').className='fact-box';
  document.getElementById('qCatBadge').style.display='none';
  updateHUD();
}

// ── FINISH ─────────────────────────────────────────────────────────
async function finishGame() {
  if (state.finished) return;
  state.finished=true;
  clearInterval(state.timerInterval);
  cancelAnimationFrame(state.animFrame);

  const acc=Math.round(state.correct/20*100);
  const score=Math.round(acc*1000 - state.timer*2 + state.maxStreak*50);
  const entry={
    name: state.playerName,
    time: state.timer,
    accuracy: acc,
    streak: state.maxStreak,
    difficulty: state.difficulty,
    score,
    date: Date.now(),
  };

  document.getElementById('finishTime').textContent=formatTime(state.timer);
  document.getElementById('finishAccuracy').textContent=acc+'%';
  document.getElementById('finishStreak').textContent=state.maxStreak+'x';
  showScreen('finish');
  setFbStatus('Finish','SAVING...','loading');

  await saveToFirebase(entry);

  const lb=getLeaderboard('all');
  const rank=lb.findIndex(e=>e.score===score&&e.name===entry.name)+1||lb.length;
  document.getElementById('finishRank').textContent='#'+(rank||'?');
  renderLeaderboard('lbBody', lb, entry);
}

// ── LEADERBOARD ───────────────────────────────────────────────────
function renderLeaderboard(elId, lb, highlight) {
  const el=document.getElementById(elId);
  if (!lb||!lb.length) {
    el.innerHTML='<div style="padding:14px;font-family:Share Tech Mono,monospace;font-size:11px;color:#4a6878;text-align:center;">NO ENTRIES YET</div>';
    return;
  }
  const diffBadge={easy:'<span style="color:var(--correct);font-size:9px;">E</span>',normal:'<span style="color:var(--accent);font-size:9px;">N</span>',hard:'<span style="color:var(--wrong);font-size:9px;">H</span>'};
  const rankClass=(i)=>i===0?'lb-rank gold':i===1?'lb-rank silver':i===2?'lb-rank bronze':'lb-rank';
  el.innerHTML=lb.slice(0,50).map((e,i)=>{
    const isHL=highlight&&e.name===highlight.name&&Math.abs(e.time-highlight.time)<2;
    return `<div class="lb-row ${isHL?'highlight-new':''}">
      <span class="${rankClass(i)}">${i===0?'🥇':i===1?'🥈':i===2?'🥉':i+1}</span>
      <span class="lb-name">${escapeHtml(e.name||'ANON')}</span>
      <span class="lb-time">${formatTime(e.time||0)}</span>
      <span class="lb-score">${e.accuracy||0}%</span>
      <span class="lb-diff">${diffBadge[e.difficulty]||'—'}</span>
    </div>`;
  }).join('');
}

function escapeHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── SCREENS ───────────────────────────────────────────────────────
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.add('hidden'));
  const el=document.getElementById(name+'Screen');
  if(el) el.classList.remove('hidden');
  state.screen=name;
}

// ── CHARACTER PREVIEW ─────────────────────────────────────────────
function drawCharPreview() {
  const c=document.getElementById('charPreview');
  const ctx=c.getContext('2d');
  ctx.clearRect(0,0,c.width,c.height);
  const s=2, px=c.width/2, py=c.height/2+5;

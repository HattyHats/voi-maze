  localStorage.setItem('voi_leaderboard_v2', JSON.stringify(lb.slice(0, 100)));
}

function getLocalLeaderboard() {
  try { return JSON.parse(localStorage.getItem('voi_leaderboard_v2')) || []; }
  catch { return []; }
}

function getLeaderboard(diffFilter) {
  const src = fbConnected && allLeaderboardEntries.length
